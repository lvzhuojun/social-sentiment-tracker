# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/
.conda/

# ── Trained model files (too large for git) ──────────────────────────────────
models/*.pkl
models/*.pt
models/*.bin
models/*.h5
models/*.onnx

# ── Raw / sensitive data (never commit raw datasets) ─────────────────────────
data/raw/
# Processed splits are derived from raw data — regenerate with split_data()
data/processed/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints
# Executed notebooks contain local absolute paths in cell outputs — don't commit
*_executed.ipynb

# ── IDE / editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Secrets / credentials ────────────────────────────────────────────────────
.env
.env.*
secrets.yaml
credentials.json

# ── Streamlit ────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Coverage / test artefacts ─────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/

# ── Generated training metrics and analysis artefacts ────────────────────────
reports/metrics.json
reports/tuning_results.json
reports/error_analysis_test.csv
models/*.json

# ── One-off / temporary scripts (not part of the public API) ─────────────────
run_training.py
take_screenshots.py

# ── Runtime logs ─────────────────────────────────────────────────────────────
logs/

# ── Local Claude Code config (never upload to GitHub) ────────────────────────
CLAUDE.md
HANDOFF.md
INTERVIEW_GUIDE.md
