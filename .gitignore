# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/
.conda/

# ── Trained model files (too large for git) ──────────────────────────────────
models/*.pkl
models/*.pt
models/*.bin
models/*.h5
models/*.onnx

# ── Raw / sensitive data (never commit raw datasets) ─────────────────────────
data/raw/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── IDE / editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Secrets / credentials ────────────────────────────────────────────────────
.env
.env.*
secrets.yaml
credentials.json

# ── Streamlit ────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Coverage / test artefacts ─────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
